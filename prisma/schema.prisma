generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id                 String         @id @default(cuid())
  nameAr             String
  nameEn             String?
  representativeName String
  logo               String?
  stamp              String?
  authUserId         String?        @unique
  canEditTemplates   Boolean        @default(false)
  approvalStatus     ApprovalStatus @default(PENDING)
  approvedAt         DateTime?
  approvedBy         String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  contracts          Contract[]
  templates          Template[]
  tenants            Tenant[]
  users              User[]

  @@index([approvalStatus])
}

model User {
  id         String   @id @default(cuid())
  authUserId String   @unique
  email      String   @unique
  name       String
  role       UserRole @default(STAFF)
  companyId  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  company    Company? @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([email])
  @@index([authUserId])
}

model Tenant {
  id             String     @id @default(cuid())
  companyId      String
  tenantType     TenantType @default(INDIVIDUAL)
  tenantName     String?
  namePart1      String?
  namePart2      String?
  namePart3      String?
  namePart4      String?
  nationality    String?
  civilId        String?
  workAddress    String?
  phone          String?
  companyName    String?
  repName        String?
  repCivilId     String?
  repNationality String?
  repPhone       String?
  legalCapacity  String?
  legalDoc       String?
  legalDocDate   DateTime?
  companyAddress String?
  idImageUrl     String?
  ocrData        Json?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  contracts      Contract[]
  company        Company    @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([civilId])
  @@index([companyName])
}

model Template {
  id           String           @id @default(cuid())
  type         ContractType
  nameAr       String
  version      Int              @default(1)
  isActive     Boolean          @default(true)
  isGlobal     Boolean          @default(false)
  clonedFromId String?
  companyId    String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  contracts    Contract[]
  company      Company?         @relation(fields: [companyId], references: [id])
  clauses      TemplateClause[]

  @@index([companyId, type])
  @@index([isGlobal, type])
}

model TemplateClause {
  id           String   @id @default(cuid())
  templateId   String
  order        Int
  titleAr      String?
  contentAr    String
  contentEn    String?
  isOptional   Boolean  @default(false)
  conditionKey String?
  variables    Json?
  template     Template @relation(fields: [templateId], references: [id])

  @@index([templateId, order])
}

model Contract {
  id                 String              @id @default(cuid())
  contractNumber     String
  type               ContractType
  status             ContractStatus      @default(DRAFT)
  templateId         String
  tenantId           String
  companyId          String
  creationDate       DateTime            @default(now())
  startDate          DateTime
  endDate            DateTime
  durationYears      Int
  durationText       String?
  hasGracePeriod     Boolean             @default(false)
  gracePeriodStart   DateTime?
  gracePeriodEnd     DateTime?
  gracePeriodText    String?
  monthlyRent        Float
  monthlyRentText    String?
  deposit            Float?
  advance            Float?
  advanceText        String?
  paymentStartDate   DateTime?
  electricityOn      UtilityParty        @default(TENANT)
  waterOn            UtilityParty        @default(TENANT)
  propertyBlock      String?
  propertyZone       String?
  propertySection    String?
  propertyStreet     String?
  propertyAlley      String?
  unitNumber         String?
  floor              String?
  autoNumber         String?
  residentialPurpose ResidentialPurpose?
  occupantsCount     Int?
  occupantsCompany   String?
  businessPurpose    String?
  hasGuarantor       Boolean             @default(false)
  activationPeriod   Int?
  contractData       Json
  clausesSnapshot    Json?
  pdfUrl             String?
  wordUrl            String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  addendums          Addendum[]
  company            Company             @relation(fields: [companyId], references: [id])
  template           Template            @relation(fields: [templateId], references: [id])
  tenant              Tenant              @relation(fields: [tenantId], references: [id])

  @@index([companyId, status])
  @@index([tenantId])
  @@index([type])
  @@index([contractNumber])
}

model Addendum {
  id           String       @id @default(cuid())
  type         AddendumType
  contractId   String
  creationDate DateTime     @default(now())
  content      String?
  pdfUrl       String?
  wordUrl      String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  contract     Contract     @relation(fields: [contractId], references: [id])

  @@index([contractId])
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  STAFF
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TenantType {
  INDIVIDUAL
  COMPANY
}

enum ContractType {
  RESIDENTIAL
  INVESTMENT_SHOP
  INVESTMENT_APARTMENT
  COMMERCIAL_OFFICE
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  RENEWED
  CANCELLED
}

enum UtilityParty {
  OWNER
  TENANT
}

enum ResidentialPurpose {
  FAMILY
  BACHELORS
  EMPLOYEES
}

enum AddendumType {
  HANDOVER
  AMENDMENT
  COMMITMENT
}
