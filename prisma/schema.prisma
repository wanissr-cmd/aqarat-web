generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id                 String     @id @default(cuid())
  nameAr             String
  nameEn             String?
  representativeName String
  logo               String?
  stamp              String?
  authUserId         String?    @unique // ✅ ربط مع Supabase Auth (المالك الأساسي)
  users              User[]
  contracts          Contract[]
  templates          Template[]
  tenants            Tenant[]
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}

model User {
  id         String   @id @default(cuid())
  authUserId String   @unique // ✅ ربط مع Supabase Auth
  email      String   @unique
  name       String
  role       UserRole @default(STAFF)
  company    Company  @relation(fields: [companyId], references: [id])
  companyId  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId])
  @@index([email])
  @@index([authUserId])
}

enum UserRole {
  ADMIN
  STAFF
}

model Tenant {
  id             String      @id @default(cuid())
  company        Company     @relation(fields: [companyId], references: [id])
  companyId      String
  tenantType     TenantType  @default(INDIVIDUAL)
  tenantName     String?
  namePart1      String?
  namePart2      String?
  namePart3      String?
  namePart4      String?
  nationality    String?
  civilId        String?
  workAddress    String?
  phone          String?
  companyName    String?
  repName        String?
  repCivilId     String?
  repNationality String?
  repPhone       String?
  legalCapacity  String?
  legalDoc       String?
  legalDocDate   DateTime?
  companyAddress String?
  idImageUrl     String?
  ocrData        Json?
  contracts      Contract[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([companyId])
  @@index([civilId])
  @@index([companyName])
}

enum TenantType {
  INDIVIDUAL
  COMPANY
}

model Template {
  id        String           @id @default(cuid())
  type      ContractType
  nameAr    String
  version   Int              @default(1)
  isActive  Boolean          @default(true)
  clauses   TemplateClause[]
  company   Company          @relation(fields: [companyId], references: [id])
  companyId String
  contracts Contract[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([companyId, type])
}

model TemplateClause {
  id           String   @id @default(cuid())
  template     Template @relation(fields: [templateId], references: [id])
  templateId   String
  order        Int
  titleAr      String?
  contentAr    String
  contentEn    String?
  isOptional   Boolean  @default(false)
  conditionKey String?
  variables    Json?

  @@index([templateId, order])
}

model Contract {
  id                 String              @id @default(cuid())
  type               ContractType
  status             ContractStatus      @default(DRAFT)
  template           Template            @relation(fields: [templateId], references: [id])
  templateId         String
  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  tenantId           String
  company            Company             @relation(fields: [companyId], references: [id])
  companyId          String
  creationDate       DateTime            @default(now())
  startDate          DateTime
  endDate            DateTime
  durationYears      Int
  durationText       String?
  hasGracePeriod     Boolean             @default(false)
  gracePeriodStart   DateTime?
  gracePeriodEnd     DateTime?
  gracePeriodText    String?
  monthlyRent        Float
  monthlyRentText    String?
  deposit            Float?
  advance            Float?
  advanceText        String?
  paymentStartDate   DateTime?
  electricityOn      UtilityParty        @default(TENANT)
  waterOn            UtilityParty        @default(TENANT)
  propertyBlock      String?
  propertyZone       String?
  propertySection    String?
  propertyStreet     String?
  propertyAlley      String?
  unitNumber         String?
  floor              String?
  autoNumber         String?
  residentialPurpose ResidentialPurpose?
  occupantsCount     Int?
  occupantsCompany   String?
  businessPurpose    String?
  hasGuarantor       Boolean             @default(false)
  activationPeriod   Int?
  contractData       Json
  clausesSnapshot    Json?
  pdfUrl             String?
  wordUrl            String?
  addendums          Addendum[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  @@index([companyId, status])
  @@index([tenantId])
  @@index([type])
}

model Addendum {
  id           String       @id @default(cuid())
  type         AddendumType
  contract     Contract     @relation(fields: [contractId], references: [id])
  contractId   String
  creationDate DateTime     @default(now())
  content      String?
  pdfUrl       String?
  wordUrl      String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([contractId])
}

enum ContractType {
  RESIDENTIAL
  INVESTMENT_SHOP
  INVESTMENT_APARTMENT
  COMMERCIAL_OFFICE
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  RENEWED
  CANCELLED
}

enum UtilityParty {
  OWNER
  TENANT
}

enum ResidentialPurpose {
  FAMILY
  BACHELORS
  EMPLOYEES
}

enum AddendumType {
  HANDOVER
  AMENDMENT
  COMMITMENT
}
